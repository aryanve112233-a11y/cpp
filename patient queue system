#include <iostream>
using namespace std;

class patient {
private:
    struct node {
        node* next;
    };

    node* head;

    bool isEmpty() {
        return head == nullptr;
    }

public:
    // Constructor
    patient() {
        head = nullptr;
    }

    // Add Emergency Patient (Front)
    void addEmergency(int id) {
        node* newnode = new node;
        newnode->patientid = id;
        newnode->next = head;
        head = newnode;

        cout << "Emergency patient added: " << id << endl;
    }

    // Add Regular Patient (End)
    void addRegular(int id) {
        node* newnode = new node;
        newnode->patientid = id;
        newnode->next = nullptr;

        if (isEmpty()) {
            head = newnode;
        }
        else {
            node* temp = head;
            while (temp->next != nullptr) {
                temp = temp->next;
            }
            temp->next = newnode;
        }

        cout << "Patient added: " << id << endl;
    }

    // Treat Patient (Remove from front)
    void treatPatient() {
        if (isEmpty()) {
            cout << "No patient to treat.\n";
            return;
        }

        node* temp = head;
        cout << "Treating patient: " << head->patientid << endl;

        head = head->next;
        delete temp;
    }

    // Display Queue
    void display() {
        if (isEmpty()) {
            cout << "No patients in queue.\n";
            return;
        }

        node* temp = head;
        cout << "Patient Queue: ";

        while (temp != nullptr) {
            cout << temp->patientid << " -> ";
            temp = temp->next;
        }

        cout << "NULL\n";
    }

    // Count Patients
    int countPatients() {
        int count = 0;
        node* temp = head;

        while (temp != nullptr) {
            count++;
            temp = temp->next;
        }

        return count;
    }

    // Search Patient
    void searchPatient(int id) {
        node* temp = head;

        while (temp != nullptr) {
            if (temp->patientid == id) {
                cout << "Patient " << id << " found in queue.\n";
                return;
            }
            temp = temp->next;
        }

        cout << "Patient not found.\n";
    }

    // Reverse Queue
    void reverse() {
        node* prev = nullptr;
        node* current = head;
        node* next = nullptr;

        while (current != nullptr) {
            next = current->next;
            current->next = prev;
            prev = current;
            current = next;
        }

        head = prev;
        cout << "Queue reversed.\n";
    }

    // Update Patient ID by position
    void update(int pos, int nid) {
        node* temp = head;

        for (int i = 1; i < pos && temp != nullptr; i++) {
            temp = temp->next;
        }

        if (temp == nullptr) {
            cout << "Patient not found\n";
        }
        else {
            temp->patientid = nid;
            cout << "Patient ID updated\n";
        }
    }

    // Display count
    void displaycount() {
        if (isEmpty()) {
            cout << "No patients in queue.\n";
            return;
        }

        int count = 0;
        node* temp = head;

        while (temp != nullptr) {
            count++;
            temp = temp->next;
        }

        cout << "Number of patients in queue: " << count << endl;
    }

    // Destructor
    ~patient() {
        while (!isEmpty()) {
            treatPatient();
        }
    }
};

int main() {
    patient p;
    int choice, id, pos;

    do {
        cout << "\n===== HOSPITAL PATIENT SYSTEM =====\n";
        cout << "1. Add Emergency Patient\n";
        cout << "2. Add Regular Patient\n";
        cout << "3. Treat Patient\n";
        cout << "4. Display Queue\n";
        cout << "5. Count Patients\n";
        cout << "6. Search Patient\n";
        cout << "7. Reverse Queue\n";
        cout << "8. Update Patient ID\n";
        cout << "9. Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        switch (choice) {

        case 1:
            cout << "Enter Patient ID: ";
            cin >> id;
            p.addEmergency(id);
            break;

        case 2:
            cout << "Enter Patient ID: ";
            cin >> id;
            p.addRegular(id);
            break;

        case 3:
            p.treatPatient();
            break;

        case 4:
            p.display();
            break;

        case 5:
            cout << "Total Patients: " << p.countPatients() << endl;
            break;

        case 6:
            cout << "Enter Patient ID to search: ";
            cin >> id;
            p.searchPatient(id);
            break;

        case 7:
            p.reverse();
            break;

        case 8:
            cout << "Enter position to update: ";
            cin >> pos;
            cout << "Enter new Patient ID: ";
            cin >> id;
            p.update(pos, id);
            break;

        case 9:
            cout << "Exiting system...\n";
            break;

        default:
            cout << "Invalid choice.\n";
        }

    } while (choice != 9);

    return 0;
}